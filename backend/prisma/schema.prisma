generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String?
  name      String
  role      Role      @default(USER)
  googleId  String?   @unique
  avatar    String?
  phone     String?
  addresses Address[]
  orders    Order[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Address {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  phone     String
  street    String
  city      String
  state     String
  pincode   String
  isDefault Boolean @default(false)
}

model Product {
  id         String      @id @default(cuid())
  name       String
  price      Int
  mrp        Int
  category   String
  stock      Int
  image      String
  badge      String?
  desc       String
  rating     Float       @default(0)
  reviews    Int         @default(0)
  isActive   Boolean     @default(true)
  orderItems OrderItem[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model Order {
  id             String      @id @default(cuid())
  userId         String
  user           User        @relation(fields: [userId], references: [id])
  items          OrderItem[]
  total          Int
  status         OrderStatus @default(PENDING)
  paymentId      String?
  paymentOrderId String?
  addressName    String
  addressPhone   String
  addressStreet  String
  addressCity    String
  addressState   String
  addressPincode String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  qty       Int
  price     Int
}

enum Role {
  USER
  ADMIN
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}
